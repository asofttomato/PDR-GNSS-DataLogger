<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <RelativeLayout
        android:id="@+id/layout_map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_nav_bar">

        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2E2E2E"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDR 未启动"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tv_map_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前底图：OpenStreetMap"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <EditText
                    android:id="@+id/et_height"
                    android:layout_width="65dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:hint="身高(m)"
                    android:text="1.75"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="14sp"
                    android:inputType="numberDecimal"
                    android:backgroundTint="#00BCD4"
                    android:gravity="center" />
            </LinearLayout>
            <Button
                android:id="@+id/btn_refresh_gps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="刷新GPS"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#455A64" />
            <Button
                android:id="@+id/btn_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开始导航"
                android:textSize="12sp"
                android:backgroundTint="#009688" />
        </LinearLayout>

        <org.osmdroid.views.MapView
            android:id="@+id/map_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/top_bar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_margin="16dp"
            android:background="#CC000000"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/tv_relative_pos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="相对原点: X=0.0m, Y=0.0m"
                android:textColor="#00E676"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/tv_total_dist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="累计行走: 0.00 m (0 步)"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layout_collect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_nav_bar"
        android:background="#1E1E1E"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="九轴 + 四元数数据采集"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/et_filename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="输入保存的文件名 (如 walk_data_01)"
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00BCD4"
            android:layout_marginBottom="20dp"
            android:inputType="text" />

        <Button
            android:id="@+id/btn_record_toggle"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="开始录制数据"
            android:textSize="18sp"
            android:backgroundTint="#E53935" />

        <TextView
            android:id="@+id/tv_record_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="状态: 待机\n\n已采集数据: 0 行"
            android:textColor="#AEEA00"
            android:textSize="16sp"
            android:lineSpacingExtra="8dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="#212121"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_tab_map"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📍 实时导航"
            android:background="#333333"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_tab_collect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="💾 数据采集"
            android:background="#212121"
            android:textColor="#888888" />
    </LinearLayout>

</RelativeLayout>